// prisma/schema.prisma

generator client {
  provider                     = "prisma-client-py"
  interface                    = "asyncio"
  recursive_type_depth         = 5
  enable_experimental_decimal  = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CEO
  DIRECTOR
  HR
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  RECEIVED
  DUE
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

// ─── FIVERR ───────────────────────────────────────────
model FiverrProfile {
  id          String         @id @default(cuid())
  profileName String         @unique
  isActive    Boolean        @default(true)
  entries     FiverrEntry[]
  orders      FiverrOrder[]

  @@map("fiverr_profiles")
}

model FiverrEntry {
  id               String        @id @default(cuid())
  date             DateTime      @db.Date
  availableWithdraw Decimal      @db.Decimal(12, 2)
  notCleared       Decimal       @db.Decimal(12, 2) @default(0)
  activeOrders     Int           @default(0)
  submitted        Decimal       @db.Decimal(12, 2) @default(0)
  withdrawn        Decimal       @db.Decimal(12, 2) @default(0)
  sellerPlus       Boolean       @default(false)
  promotion        Decimal       @db.Decimal(12, 2) @default(0)
  profileId        String
  profile          FiverrProfile @relation(fields: [profileId], references: [id])
  createdAt        DateTime      @default(now())

  @@unique([profileId, date])
  @@map("fiverr_entries")
}

model FiverrOrder {
  id          String        @id @default(cuid())
  date        DateTime      @db.Date
  buyerName   String
  orderId     String        @unique
  amount      Decimal       @db.Decimal(12, 2)
  profileId   String
  profile     FiverrProfile @relation(fields: [profileId], references: [id])
  createdAt   DateTime      @default(now())

  @@map("fiverr_orders")
}

// ─── UPWORK ───────────────────────────────────────────
model UpworkProfile {
  id          String         @id @default(cuid())
  profileName String         @unique
  isActive    Boolean        @default(true)
  entries     UpworkEntry[]
  orders      UpworkOrder[]

  @@map("upwork_profiles")
}

model UpworkEntry {
  id               String        @id @default(cuid())
  date             DateTime      @db.Date
  availableWithdraw Decimal      @db.Decimal(12, 2)
  pending          Decimal       @db.Decimal(12, 2) @default(0)
  inReview         Decimal       @db.Decimal(12, 2) @default(0)
  workInProgress   Decimal       @db.Decimal(12, 2) @default(0)
  withdrawn        Decimal       @db.Decimal(12, 2) @default(0)
  connects         Int           @default(0)
  upworkPlus       Boolean       @default(false)
  profileId        String
  profile          UpworkProfile @relation(fields: [profileId], references: [id])
  createdAt        DateTime      @default(now())

  @@unique([profileId, date])
  @@map("upwork_entries")
}

model UpworkOrder {
  id          String        @id @default(cuid())
  date        DateTime      @db.Date
  clientName  String
  orderId     String        @unique
  amount      Decimal       @db.Decimal(12, 2)
  profileId   String
  profile     UpworkProfile @relation(fields: [profileId], references: [id])
  createdAt   DateTime      @default(now())

  @@map("upwork_orders")
}

// ─── PAYONEER ─────────────────────────────────────────
model PayoneerAccount {
  id           String             @id @default(cuid())
  accountName  String             @unique
  isActive     Boolean            @default(true)
  transactions PayoneerTransaction[]

  @@map("payoneer_accounts")
}

model PayoneerTransaction {
  id               String          @id @default(cuid())
  date             DateTime        @db.Date
  details          String
  accountFrom      String?         
  accountTo        String?         
  debit            Decimal         @db.Decimal(12, 2) @default(0)
  credit           Decimal         @db.Decimal(12, 2) @default(0)
  remainingBalance Decimal         @db.Decimal(12, 2)
  accountId        String
  account          PayoneerAccount @relation(fields: [accountId], references: [id])
  createdAt        DateTime        @default(now())

  @@map("payoneer_transactions")
}

// ─── PMAK ─────────────────────────────────────────────
model PmakAccount {
  id           String             @id @default(cuid())
  accountName  String             @unique
  isActive     Boolean            @default(true)
  transactions PmakTransaction[]

  @@map("pmak_accounts")
}

model PmakTransaction {
  id               String      @id @default(cuid())
  date             DateTime    @db.Date
  details          String
  accountFrom      String?         
  accountTo        String?         
  debit            Decimal     @db.Decimal(12, 2) @default(0)
  credit           Decimal     @db.Decimal(12, 2) @default(0)
  remainingBalance Decimal     @db.Decimal(12, 2)
  accountId        String
  account          PmakAccount @relation(fields: [accountId], references: [id])
  createdAt        DateTime    @default(now())

  @@map("pmak_transactions")
}

// ─── OUTSIDE ORDERS ───────────────────────────────────
model OutsideOrder {
  id                  String        @id @default(cuid())
  date                DateTime      @db.Date
  clientId            String
  clientName          String
  clientLink          String?
  orderDetails        String
  orderSheet          String?       // file path or URL
  assignTeam          String?
  orderStatus         OrderStatus   @default(PENDING)
  orderAmount         Decimal       @db.Decimal(12, 2)
  receiveAmount       Decimal       @db.Decimal(12, 2) @default(0)
  dueAmount           Decimal       @db.Decimal(12, 2) @default(0)
  paymentMethod       String?
  paymentMethodDetails String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@map("outside_orders")
}

// ─── DOLLAR EXCHANGE ──────────────────────────────────
model DollarExchange {
  id            String        @id @default(cuid())
  date          DateTime      @db.Date
  details       String
  accountFrom   String?       
  accountTo     String?       
  debit         Decimal       @db.Decimal(12, 2) @default(0)
  credit        Decimal       @db.Decimal(12, 2) @default(0)
  rate          Decimal       @db.Decimal(8, 2)
  totalBdt      Decimal       @db.Decimal(14, 2)  // rate * exchange amount
  paymentStatus PaymentStatus @default(DUE)
  createdAt     DateTime      @default(now())

  @@map("dollar_exchanges")
}

// ─── CARD SHARING ─────────────────────────────────────
model CardSharing {
  id               String   @id @default(cuid())
  serialNo         String   @unique
  details          String?
  payoneerAccount  String
  cardNo           String   // store encrypted
  cardExpire       String
  cardCvc          String   // store encrypted
  cardVendor       String
  cardLimit        Decimal  @db.Decimal(12, 2)
  cardPaymentRcv   Decimal  @db.Decimal(12, 2) @default(0)
  cardRcvBank      String?
  mailDetails      String?
  screenshotPath   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("card_sharing")
}

// ─── HR EXPENSE ───────────────────────────────────────
model HrExpense {
  id               String   @id @default(cuid())
  date             DateTime @db.Date
  details          String
  accountFrom      String?         
  accountTo        String?         
  debit            Decimal  @db.Decimal(12, 2) @default(0)
  credit           Decimal  @db.Decimal(12, 2) @default(0)
  remainingBalance Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())

  @@map("hr_expenses")
}

// ─── INVENTORY ────────────────────────────────────────
model Inventory {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  itemName    String
  category    String?
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2) @default(0)
  totalPrice  Decimal  @db.Decimal(12, 2) @default(0)
  condition   String?
  assignedTo  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("inventory")
}

// ─── INVITATIONS ───────────────────────────────────────────────
enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model Invitation {
  id          String           @id @default(cuid())
  email       String
  role        Role
  inviteToken String           @unique
  status      InvitationStatus @default(PENDING)
  invitedBy   String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([email])
  @@index([inviteToken])
  @@index([status])

  @@map("invitations")
}